{
  "name": "cortex-vscode",
  "displayName": "Cortex VS Code",
  "description": "Browse, search, and manage Cortex knowledge directly from VS Code.",
  "version": "0.3.4",
  "publisher": "alaarab",
  "author": "Ala Arab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alaarab/cortex.git",
    "directory": "vscode-extension"
  },
  "homepage": "https://github.com/alaarab/cortex/tree/main/vscode-extension",
  "bugs": {
    "url": "https://github.com/alaarab/cortex/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "cortex",
    "knowledge",
    "memory",
    "mcp",
    "agent"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cortex.search",
        "title": "Cortex: Search Knowledge",
        "icon": "$(search)"
      },
      {
        "command": "cortex.showGraph",
        "title": "Cortex: Show Entity Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "cortex.refresh",
        "title": "Cortex: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "cortex.addFinding",
        "title": "Cortex: Add Finding"
      },
      {
        "command": "cortex.setActiveProject",
        "title": "Cortex: Set Active Project"
      },
      {
        "command": "cortex.openFinding",
        "title": "Cortex: Open Finding"
      },
      {
        "command": "cortex.openProjectFile",
        "title": "Cortex: Open Project File"
      },
      {
        "command": "cortex.openSkill",
        "title": "Cortex: Open Skill"
      },
      {
        "command": "cortex.toggleSkill",
        "title": "Cortex: Toggle Skill"
      },
      {
        "command": "cortex.toggleHook",
        "title": "Cortex: Toggle Hook"
      },
      {
        "command": "cortex.openTask",
        "title": "Cortex: Open Task"
      },
      {
        "command": "cortex.openQueueItem",
        "title": "Cortex: Open Queue Item"
      },
      {
        "command": "cortex.openSessionOverview",
        "title": "Cortex: Open Session Overview",
        "icon": "$(preview)"
      },
      {
        "command": "cortex.copySessionId",
        "title": "Cortex: Copy Session ID",
        "icon": "$(copy)"
      },
      {
        "command": "cortex.filterFindingsByDate",
        "title": "Cortex: Filter Findings by Date",
        "icon": "$(calendar)"
      },
      {
        "command": "cortex.sync",
        "title": "Cortex: Sync",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "cortex.doctor",
        "title": "Cortex: Doctor",
        "icon": "$(checklist)"
      },
      {
        "command": "cortex.hooksStatus",
        "title": "Cortex: Hooks Status"
      },
      {
        "command": "cortex.toggleHooksCommand",
        "title": "Cortex: Toggle Hooks"
      },
      {
        "command": "cortex.manageProject",
        "title": "Cortex: Manage Project"
      },
      {
        "command": "cortex.uninstall",
        "title": "Cortex: Uninstall Cortex"
      },
      {
        "command": "cortex.switchProfile",
        "title": "Cortex: Set This Machine's Profile"
      },
      {
        "command": "cortex.configureMachine",
        "title": "Cortex: Set Machine Alias"
      },
      {
        "command": "cortex.openMachinesConfig",
        "title": "Cortex: Open machines.yaml"
      },
      {
        "command": "cortex.addTask",
        "title": "Cortex: Add Task",
        "icon": "$(add)"
      },
      {
        "command": "cortex.completeTask",
        "title": "Cortex: Complete Task",
        "icon": "$(check)"
      },
      {
        "command": "cortex.removeTask",
        "title": "Cortex: Delete Task",
        "icon": "$(trash)"
      },
      {
        "command": "cortex.removeFinding",
        "title": "Cortex: Remove Finding",
        "icon": "$(trash)"
      },
      {
        "command": "cortex.rejectQueueItem",
        "title": "Cortex: Reject Queue Item",
        "icon": "$(trash)"
      },
      {
        "command": "cortex.pinMemory",
        "title": "Cortex: Pin Memory"
      }
    ],
    "keybindings": [
      {
        "command": "cortex.search",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cortex.addFinding",
          "when": "editorHasSelection"
        }
      ],
      "view/item/context": [
        {
          "command": "cortex.filterFindingsByDate",
          "when": "viewItem == cortex.category.findings",
          "group": "inline"
        },
        {
          "command": "cortex.toggleHook",
          "when": "viewItem == cortex.hookItem",
          "group": "inline"
        },
        {
          "command": "cortex.completeTask",
          "when": "viewItem == cortex.task.active",
          "group": "inline"
        },
        {
          "command": "cortex.removeTask",
          "when": "viewItem == cortex.task.active || viewItem == cortex.task.done",
          "group": "inline"
        },
        {
          "command": "cortex.removeFinding",
          "when": "viewItem == cortex.finding",
          "group": "inline"
        },
        {
          "command": "cortex.rejectQueueItem",
          "when": "viewItem == cortex.queue.item",
          "group": "inline"
        },
        {
          "command": "cortex.openSessionOverview",
          "when": "viewItem == cortex.session",
          "group": "inline"
        },
        {
          "command": "cortex.copySessionId",
          "when": "viewItem == cortex.session",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "cortex.showGraph",
          "when": "view == cortex.explorer",
          "group": "navigation"
        },
        {
          "command": "cortex.search",
          "when": "view == cortex.explorer",
          "group": "navigation"
        },
        {
          "command": "cortex.refresh",
          "when": "view == cortex.explorer",
          "group": "navigation"
        },
        {
          "command": "cortex.sync",
          "when": "view == cortex.explorer",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cortex",
          "title": "Cortex",
          "icon": "media/cortex.svg"
        }
      ]
    },
    "views": {
      "cortex": [
        {
          "id": "cortex.explorer",
          "name": "Explorer"
        }
      ]
    },
    "configuration": {
      "title": "Cortex",
      "properties": {
        "cortex.mcpServerPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Cortex MCP server entrypoint JavaScript file. Leave blank to auto-detect a global install."
        },
        "cortex.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Path to the Node.js binary used to run the cortex MCP server."
        },
        "cortex.storePath": {
          "type": "string",
          "default": "",
          "description": "Path to the Cortex store directory. Leave blank to use ~/.cortex."
        },
        "cortex.onboardingComplete": {
          "type": "boolean",
          "default": false,
          "description": "Internal extension flag that tracks whether first-run onboarding prompts have already been shown."
        },
        "cortex.proactivity": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "default": "high",
          "description": "How proactively Cortex captures findings and tasks. High: always auto-capture. Medium: only when explicit signals detected. Low: never auto-capture."
        },
        "cortex.proactivityFindings": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "default": "high",
          "description": "Override proactivity level specifically for findings capture."
        },
        "cortex.proactivityTasks": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "default": "high",
          "description": "Override proactivity level specifically for task capture."
        },
        "cortex.autoExtract": {
          "type": "boolean",
          "default": true,
          "description": "Automatically extract insights from project context on each prompt."
        },
        "cortex.autoCapture": {
          "type": "boolean",
          "default": false,
          "description": "Extract insights from conversation transcripts at session end."
        },
        "cortex.taskMode": {
          "type": "string",
          "enum": ["off", "manual", "suggest", "auto"],
          "default": "auto",
          "description": "Task automation mode. Off: tasks disabled. Manual: only when explicitly requested. Suggest: Claude suggests but waits for confirmation. Auto: Claude adds tasks automatically."
        },
        "cortex.hooksEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable cortex hooks globally. When disabled, no hooks fire on prompts or session events."
        },
        "cortex.findingSensitivity": {
          "type": "string",
          "enum": ["minimal", "conservative", "balanced", "aggressive"],
          "default": "balanced",
          "enumDescriptions": [
            "Only save findings when explicitly asked. No auto-capture.",
            "Save decisions and pitfalls only. Auto-capture: 3/session max.",
            "Save non-obvious patterns and decisions. Auto-capture: 10/session.",
            "Save everything worth remembering. Auto-capture: 20/session."
          ],
          "description": "Controls how aggressively Cortex captures findings and auto-captures insights from sessions."
        },
        "cortex.semanticDedup": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable semantic duplicate detection for **offline maintenance commands** (`cortex maintain consolidate`, `cortex maintain extract`) when no agent session is active. Live dedup during `add_finding` uses the active agent (Claude/GPT) instead — no extra API call needed. Batch mode uses a separate LLM call per finding group. Results cached 24h. Cost scales with `cortex.llmModel` (~$0.01/batch-session with Haiku)."
        },
        "cortex.semanticConflict": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable semantic conflict detection for **offline maintenance commands** (`cortex maintain consolidate`, `cortex maintain extract`) when no agent session is active. Live conflict detection during `add_finding` uses the active agent instead. Batch mode uses a separate LLM call per finding group. Results cached 24h. Cost scales with `cortex.llmModel` (~$0.01/batch-session with Haiku)."
        },
        "cortex.llmModel": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "claude-haiku-4-5-20251001",
            "claude-sonnet-4-6",
            "claude-opus-4-6",
            "gpt-4o-mini",
            "gpt-4o"
          ],
          "enumDescriptions": [
            "Use server default (Haiku)",
            "Claude Haiku 4.5 — recommended for offline batch operations (~$0.01/session)",
            "Claude Sonnet 4.6 — higher quality, ~10x more expensive than Haiku",
            "Claude Opus 4.6 — expensive for batch operations; not recommended",
            "GPT-4o mini — cost-effective alternative for batch operations",
            "GPT-4o — expensive for batch operations; not recommended"
          ],
          "markdownDescription": "Model for **offline cortex operations** (`consolidate`, `extract`). Sets `CORTEX_LLM_MODEL`. **Live dedup uses the active agent instead** — this setting only applies when running maintenance commands without an active session. Haiku is recommended for batch operations."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node -e \"try{require('fs').copyFileSync(require('path').resolve(__dirname,'..','mcp','dist','memory-ui-graph.js'),require('path').resolve(__dirname,'out','memory-ui-graph.js'));console.log('Copied memory-ui-graph.js to out/')}catch(e){console.warn('Note: mcp/dist/memory-ui-graph.js not found, graph engine will use repo-relative path')}\"",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies",
    "publish:extension": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.5.4"
  }
}
