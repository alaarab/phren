{
  "name": "cortex-vscode",
  "displayName": "Cortex VS Code",
  "description": "Browse, search, and manage Cortex knowledge directly from VS Code.",
  "version": "0.0.8",
  "publisher": "alaarab",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cortex.search",
        "title": "Cortex: Search Knowledge",
        "icon": "$(search)"
      },
      {
        "command": "cortex.showGraph",
        "title": "Cortex: Show Entity Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "cortex.refresh",
        "title": "Cortex: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "cortex.addFinding",
        "title": "Cortex: Add Finding"
      },
      {
        "command": "cortex.setActiveProject",
        "title": "Cortex: Set Active Project"
      },
      {
        "command": "cortex.openFinding",
        "title": "Cortex: Open Finding"
      },
      {
        "command": "cortex.openProjectFile",
        "title": "Cortex: Open Project File"
      },
      {
        "command": "cortex.openSkill",
        "title": "Cortex: Open Skill"
      },
      {
        "command": "cortex.toggleSkill",
        "title": "Cortex: Toggle Skill"
      },
      {
        "command": "cortex.toggleHook",
        "title": "Cortex: Toggle Hook"
      },
      {
        "command": "cortex.openTask",
        "title": "Cortex: Open Task"
      }
    ],
    "keybindings": [
      {
        "command": "cortex.search",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cortex.addFinding",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "cortex.showGraph",
          "when": "view == cortex.explorer",
          "group": "navigation"
        },
        {
          "command": "cortex.search",
          "when": "view == cortex.explorer",
          "group": "navigation"
        },
        {
          "command": "cortex.refresh",
          "when": "view == cortex.explorer",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cortex",
          "title": "Cortex",
          "icon": "media/cortex.svg"
        }
      ]
    },
    "views": {
      "cortex": [
        {
          "id": "cortex.explorer",
          "name": "Explorer"
        }
      ]
    },
    "configuration": {
      "title": "Cortex",
      "properties": {
        "cortex.mcpServerPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the cortex MCP server entrypoint JavaScript file."
        },
        "cortex.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Path to the Node.js binary used to run the cortex MCP server."
        },
        "cortex.storePath": {
          "type": "string",
          "default": "",
          "description": "Path to cortex store directory (e.g. /home/user/.cortex)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.4",
    "vscode": "^1.1.37"
  }
}
