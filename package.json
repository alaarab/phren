{
  "name": "phren",
  "version": "0.1.17",
  "private": true,
  "description": "Knowledge layer for AI agents",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @phren/cli run build && playwright test",
    "validate-docs": "bash scripts/validate-docs.sh",
    "install-hooks": "cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "overrides": {
    "flatted": "^3.4.2",
    "undici": "^7.10.0",
    "hono": "^4.12.14",
    "uuid": "^14.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.8",
      "hono": "^4.12.14",
      "uuid": "^14.0.0"
    }
  }
}
