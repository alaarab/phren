{
  "name": "@alaarab/cortex",
  "version": "1.24.0",
  "description": "Long-term memory for AI agents. Stored as markdown in a git repo you own.",
  "type": "module",
  "bin": {
    "cortex": "mcp/dist/index.js"
  },
  "files": [
    "mcp/dist",
    "starter",
    "skills"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "sql.js-fts5": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "rm -rf mcp/dist && tsc -p mcp/tsconfig.json && chmod +x mcp/dist/index.js && cp mcp/src/synonyms.json mcp/dist/synonyms.json",
    "dev": "tsx mcp/src/index.ts",
    "lint": "eslint mcp/src/ --ignore-pattern '*.test.ts'",
    "validate-docs": "bash scripts/validate-docs.sh",
    "pretest": "npm run build",
    "test": "vitest run mcp/src",
    "bench": "tsx mcp/bench/locomo-runner.ts --sessions 3",
    "bench:retrieval": "tsx scripts/bench-retrieval-modes.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "memory",
    "knowledge"
  ],
  "author": "Ala Arab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alaarab/cortex.git"
  },
  "homepage": "https://github.com/alaarab/cortex#readme"
}
