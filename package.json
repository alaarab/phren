{
  "name": "phren",
  "version": "0.1.18",
  "private": true,
  "description": "Knowledge layer for AI agents",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @phren/cli run build && playwright test",
    "validate-docs": "bash scripts/validate-docs.sh",
    "install-hooks": "cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "overrides": {
    "fast-uri": "^3.1.2",
    "flatted": "^3.4.2",
    "hono": "^4.12.25",
    "ip-address": "^10.2.0",
    "undici": "^7.28.0",
    "form-data": ">=4.0.6",
    "vite": "^8.0.16",
    "uuid": "^14.0.0",
    "tmp": ">=0.2.7",
    "ws": ">=8.21.0",
    "qs": ">=6.15.2",
    "brace-expansion": ">=5.0.6",
    "markdown-it": "^14.2.0",
    "linkify-it": "^5.0.1"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.1.2",
      "vite": "^8.0.16",
      "hono": "^4.12.25",
      "ip-address": "^10.2.0",
      "undici": "^7.28.0",
      "form-data": ">=4.0.6",
      "uuid": "^14.0.0",
      "tmp@<0.2.6": ">=0.2.7",
      "ws@>=8.0.0 <8.20.1": ">=8.21.0",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "markdown-it@<14.2.0": "^14.2.0",
      "linkify-it@<5.0.1": "^5.0.1"
    }
  }
}
