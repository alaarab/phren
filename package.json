{
  "name": "@alaarab/cortex",
  "version": "1.12.0",
  "description": "Long-term memory for Claude Code",
  "type": "module",
  "bin": {
    "cortex": "mcp/dist/index.js"
  },
  "files": [
    "mcp/dist",
    "starter",
    "skills"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "glob": "^12.0.0",
    "js-yaml": "^4.1.0",
    "sql.js-fts5": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "rm -rf mcp/dist && tsc -p mcp/tsconfig.json && chmod +x mcp/dist/index.js",
    "dev": "tsx mcp/src/index.ts",
    "lint": "eslint mcp/src/ --ignore-pattern '*.test.ts'",
    "validate-docs": "bash scripts/validate-docs.sh",
    "test": "vitest run mcp/src",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "memory",
    "knowledge"
  ],
  "author": "Ala Arab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alaarab/cortex.git"
  },
  "homepage": "https://github.com/alaarab/cortex#readme"
}
