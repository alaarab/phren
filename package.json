{
  "name": "phren",
  "version": "0.1.16",
  "private": true,
  "description": "Knowledge layer for AI agents with a built-in coding agent",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @phren/cli run build && playwright test",
    "validate-docs": "bash scripts/validate-docs.sh",
    "install-hooks": "cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "turbo": "^2.5.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "overrides": {
    "flatted": "^3.4.2",
    "undici": "^7.10.0"
  }
}
